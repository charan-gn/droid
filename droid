        def action_kvm(self): self._adb_cmd("kvm")
        def action_screenshot(self): self._adb_cmd("screenshot")
        def action_record(self): self._adb_cmd("record")
        def action_info(self): self._adb_cmd("info")
        def action_wake_sleep(self): self._run_cmd(["kitty", "-e", "bash", "-c",
