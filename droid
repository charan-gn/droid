def _pick_number(max_val: int) -> Optional[int]:
    try:
        choice = input(f"  Pick a number [1-{max_val}] (q to quit): ").strip()
        if choice.lower() == "q":
            return None
        c = int(choice)
        if 1 <= c <= max_val:
            return c
    except (ValueError, EOFError):
        pass
    return None


# ── KDE Connect ───────────────────────────────────────────────────────────────

def cmd_kdeconnect(args):
    """KDE Connect device integration"""
    check_dep("kdeconnect-cli", "sudo pacman -S kdeconnect")

    def get_devices():
        r = subprocess.run(
            ["kdeconnect-cli", "--list-devices", "--id-only"],
            capture_output=True, text=True, timeout=10
        )
        devices = []
        for line in r.stdout.splitlines():
            m = re.match(r"(\S+)\s*\(.*?\)", line)
            if m:
                devices.append(m.group(1))
        if not devices:
            for line in r.stdout.splitlines():
                parts = line.strip().split()
                if parts and parts[0] and "@" not in parts[0]:
                    devices.append(parts[0])
        return devices

    def get_device_pairs():
        r = subprocess.run(
            ["kdeconnect-cli", "--list-devices"],
            capture_output=True, text=True, timeout=10
        )
        pairs = []
        for line in r.stdout.splitlines():
            m = re.search(r"(\S+)\s+\((.+?)\)", line)
            if m:
                pairs.append((m.group(1), m.group(2)))
        return pairs

    if args.action == "list":
        pairs = get_device_pairs()
        if not pairs:
            info("No KDE Connect devices found.")
            return
        bold("KDE Connect devices:")
        for dev_id, name in pairs:
            r = subprocess.run(["kdeconnect-cli", "-d", dev_id, "--ping"],
                               capture_output=True, timeout=5)
            mark = "reachable" if r.returncode == 0 else "offline"
            print(f"  {DIM}\u2022{RESET} {name} ({dev_id}) [{mark}]")

    elif args.action == "ping":
        if args.device:
            subprocess.run(["kdeconnect-cli", "-d", args.device, "--ping"])
        else:
            subprocess.run(["kdeconnect-cli", "--ping"])

    elif args.action == "send-file":
        if not args.file:
            err("Specify a file path with --file.")
            return
        cmd = ["kdeconnect-cli", "--share", args.file]
        if args.device:
            cmd.extend(["-d", args.device])
        subprocess.run(cmd)
        success(f"Sent {args.file}.")

    elif args.action == "share-url":
        url = args.url or args.file
        if not url:
            err("Specify a URL with --url.")
            return
        cmd = ["kdeconnect-cli", "--share", url]
        if args.device:
            cmd.extend(["-d", args.device])
        subprocess.run(cmd)
        success("Shared URL.")

    elif args.action == "find":
        cmd = ["kdeconnect-cli"]
        if args.device:
            cmd.extend(["-d", args.device])
        cmd.append("--ring")
        subprocess.run(cmd)
        success("Finding device...")

    elif args.action == "list-files":
        devices = get_devices()
        if not devices:
            err("No KDE Connect devices.")
            return
        target = args.device or devices[0]
        r = subprocess.run(
            ["kdeconnect-cli", "-d", target, "--list-notifications"],
            capture_output=True, text=True, timeout=10
        )
        print(r.stdout)

    elif args.action == "sms":
        if not args.number or not args.message:
            err("Usage: droid kdeconnect sms --number <phone> --message <text>")
            return
        devices = get_devices()
        if not devices:
            err("No KDE Connect devices.")
            return
        target = args.device or devices[0]
        subprocess.run(
            ["kdeconnect-cli", "-d", target, "--send-sms",
             "--number", args.number, "--message", args.message]
        )
        success(f"SMS sent to {args.number}.")

    elif args.action == "share-clip":
        devices = get_devices()
        if not devices:
            err("No KDE Connect devices.")
            return
        target = args.device or devices[0]
        r = subprocess.run(["wl-paste"], capture_output=True, text=True, timeout=5)
        text = r.stdout.strip()
        if not text:
            err("Clipboard empty.")
            return
        with tempfile.NamedTemporaryFile(mode="w", suffix=".txt", delete=False) as f:
            f.write(text)
            fname = f.name
        subprocess.run(["kdeconnect-cli", "-d", target, "--share", fname])
        os.unlink(fname)
        success(f"Clipboard shared ({len(text)} chars).")

    else:
        info("Usage: droid kdeconnect list | ping | find | send-file <path> | share-url <url> | sms <number> <msg> | share-clip")


