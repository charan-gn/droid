def cmd_default(args):
    """Default: keyboard-navigable menu interface"""
    cfg = load_config()
    conn = resolve_connection(cfg)
    from concurrent.futures import ThreadPoolExecutor as TPE

    phone = {}
    host = _get_host_info()

    def get(prop):
        if not conn.adb_ok or not conn.adb_serial:
            return "?"
        r = subprocess.run(["adb", "-s", conn.adb_serial, "shell", f"getprop {prop}"],
                           capture_output=True, text=True, timeout=5)
        return r.stdout.strip() or "?"

    def get_cmd(cmd):
        if not conn.adb_ok or not conn.adb_serial:
            return "?"
        r = subprocess.run(["adb", "-s", conn.adb_serial, "shell", cmd],
                           capture_output=True, text=True, timeout=5)
        return r.stdout.strip() or "?"

    def get_bat():
        if not conn.adb_ok or not conn.adb_serial:
            return "?"
        r = subprocess.run(["adb", "-s", conn.adb_serial, "shell", "dumpsys", "battery"],
                           capture_output=True, text=True, timeout=5)
        level = ""
        for l in r.stdout.splitlines():
            ls = l.strip()
            if ls.startswith("level:"):
                level = ls.split()[-1] + "%"
                break
        return level or "?"

    if conn.adb_ok:
        with TPE(max_workers=4) as pool:
            futs = {
                "model": pool.submit(lambda: get("ro.product.model")),
                "android": pool.submit(lambda: get("ro.build.version.release")),
                "battery": pool.submit(get_bat),
                "ram": pool.submit(lambda: get_cmd("cat /proc/meminfo | grep MemTotal")),
                "storage": pool.submit(lambda: get_cmd("df -h /data | tail -1")),
                "display": pool.submit(lambda: get_cmd("wm size")),
            }
            phone["model"] = futs["model"].result()
            phone["android"] = futs["android"].result()
            phone["battery"] = futs["battery"].result()
            ram_raw = futs["ram"].result()
            m = re.search(r'(\d+)', ram_raw)
            phone["ram"] = f"{int(m.group(1)) / 1024 / 1024:.1f} GiB" if m else "?"
            storage_raw = futs["storage"].result()
            parts = storage_raw.split()
            phone["storage"] = f"{parts[1]}·{parts[3]} free" if len(parts) >= 5 else "?"
            display_raw = futs["display"].result()
            phone["display"] = display_raw.replace("Physical size:", "").strip() or "?"

    adb_serials = _get_all_adb_serials()
