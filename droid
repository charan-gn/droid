def cmd_dashboard(args):
    """Interactive TUI dashboard with live stats + action grid"""
    try:
        from textual.app import App, ComposeResult
        from textual.widgets import Header, Footer, Button, Static
        from textual.containers import Horizontal, Vertical
        from textual.reactive import reactive
    except ImportError:
        fatal("textual not installed.\nRun: pip install textual")

    from concurrent.futures import ThreadPoolExecutor as TPE
    POLL_INTERVAL = 5

    def fetch_stats(cfg):
        conn = resolve_connection(cfg)
        adb_serials = _get_all_adb_serials()
        cfg_full = load_config()
        preferred = cfg_full.get("preferred_device", "")
        active = conn.adb_serial or preferred or (adb_serials[0] if len(adb_serials) == 1 else "")
        data = {"adb": "?", "adb_count": len(adb_serials), "adb_serial": active,
                "adb_serials": adb_serials, "preferred": preferred,
                "ssh": "?", "battery": "?", "model": "?", "tunnel": "off",
                "kiwix": "off", "kde": "?", "hostname": "?"}
        host = _get_host_info()
        data["hostname"] = host.get("hostname", "?")
        if shutil.which("kdeconnect-cli"):
            try:
                r = subprocess.run(["kdeconnect-cli", "-l", "--id-only"],
                                   capture_output=True, text=True, timeout=5)
                kdevices = [l.strip() for l in r.stdout.splitlines() if l.strip()]
                data["kde"] = f"{len(kdevices)}" if kdevices else "0"
            except Exception:
                data["kde"] = "err"
        if conn.adb_ok and active:
            data["adb"] = "connected"
            with TPE(max_workers=4) as pool:
                def get(prop):
                    r = subprocess.run(["adb", "-s", active.replace(" (unauthorized)",""),
                                       "shell", f"getprop {prop}"], capture_output=True, text=True, timeout=5)
                    return r.stdout.strip()
                def get_bat():
                    r = subprocess.run(["adb", "-s", active, "shell", "dumpsys", "battery"],
                                       capture_output=True, text=True, timeout=5)
                    level, charging = "", ""
                    for l in r.stdout.splitlines():
                        ls = l.strip()
                        if ls.startswith("level:"): level = ls.split()[-1]
                        elif "AC powered" in ls: charging = "⚡" if "true" in ls else ""
                    return f"{level}%{charging}"
                def get_tun():
                    pf = cfg.get("socks_pid_file", "")
                    if os.path.exists(pf):
                        try:
                            with open(pf) as f: pid = int(f.read().strip())
                            os.kill(pid, 0)
                            return "on"
                        except: pass
                    return "off"
                def get_kwx():
                    try:
                        r = subprocess.run(["ss", "-tulpn"], capture_output=True, text=True)
                        return "on" if f":{cfg.get('kiwix_port', 8080)} " in r.stdout else "off"
                    except: return "off"
                fs = {
                    "model": lambda: get("ro.product.model"),
                    "battery": get_bat,
                    "tunnel": get_tun,
                    "kiwix": get_kwx,
                }
                for k, fn in fs.items():
                    pool.submit(lambda k=k, fn=fn: data.update({k: fn()})).result()
        if conn.ssh_ok:
            data["ssh"] = "connected"
        return data

    class StatsBar(Static):
        data = reactive({})

        def watch_data(self, val):
            self.update(self._format_stats(val))

        def _format_stats(self, d):
            line1 = ["[bold cyan]droid[/]"]
            hostname = d.get("hostname", "")
            if hostname and hostname != "?":
                line1.append(f"🖥 {hostname}")
            if d.get("model"):
                label = d["model"]
                if d.get("adb_serial"):
                    label += f" [{d['adb_serial']}]"
                line1.append(f"📱 {label}")
            if d.get("battery"):
                line1.append(f"🔋 {d['battery']}")
            line1.append("│")
            count = d.get("adb_count", 0)
            color = "green" if d.get("adb") == "connected" else "red"
            line1.append(f"[{color}]ADB({count})[/]")
            color = "green" if d.get("ssh") == "connected" else "red"
            line1.append(f"[{color}]SSH[/]")
            kde = d.get("kde", "?")
            color = "green" if kde not in ("0", "?", "err") else "red"
            line1.append(f"[{color}]KDE {kde}[/]")
            line1.append("│")
            line1.append(f"🌐 {d.get('tunnel', 'off')}")
            line1.append(f"📚 {d.get('kiwix', 'off')}")
            out = "  ".join(line1)
            serials = d.get("adb_serials", [])
            preferred = d.get("preferred", "")
            active = d.get("adb_serial", "")
            if len(serials) > 1:
                devs = []
                for s in serials:
                    entry = f"📱 {s}"
                    if s == active:
                        entry += "  ←"
                    devs.append(entry)
                out += "\n" + "  ".join(devs)
            return out

        def on_mount(self):
            self.styles.background = "blue"
            self.styles.padding = (0, 1)

