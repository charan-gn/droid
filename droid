            serials = _get_all_adb_serials()
            cfg_check = load_config()
            preferred = cfg_check.get("preferred_device", "")
            if len(serials) > 1 and (not preferred or preferred not in serials):
                self._run_cmd(["kitty", "-e", sys.argv[0], "switch"])
            self._run_cmd(["kitty", "-e", sys.argv[0], subcmd] + list(args))

