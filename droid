        def action_device(self): self._adb_cmd("device")
        def action_host(self): self._run_cmd(self._term_cmd("host"))
        def action_switch(self): self._run_cmd(self._term_cmd("switch"))
        def action_devices(self): self._run_cmd(self._term_cmd("devices"))

    DroidTUI(load_config()).run()


