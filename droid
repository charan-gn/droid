def cmd_mount(args):
    """Mount/unmount phone via SSHFS"""
    cfg = load_config()
    conn = resolve_connection(cfg)
    ip = conn.ip
    if not ip:
        fatal("Could not detect phone IP.\nIs USB tethering or ethernet connected?")
    mount_point = cfg["mount_point"]
    storage_mount = cfg["storage_mount"]
    ssh_port = conn.ssh_port
    ssh_user = conn.ssh_user
    ssh_key = conn.ssh_key

    check_dep("sshfs", "sudo pacman -S sshfs")
    check_dep("fusermount3", "sudo pacman -S fuse3")

    def is_mounted(path):
        return subprocess.run(["mountpoint", "-q", path], capture_output=True).returncode == 0

    if args.action == "unmount":
        for mp in [mount_point, storage_mount]:
            if is_mounted(mp):
                subprocess.run(["fusermount3", "-u", mp], stdout=NULL, stderr=NULL)
                info(f"Unmounted {mp}")
        try:
            subprocess.run(["notify-send", "Phone", "Unmounted"], stdout=NULL, stderr=NULL)
        except Exception:
            pass
        return

    if is_mounted(mount_point):
        info("Already mounted.")
        return

    Path(mount_point).mkdir(parents=True, exist_ok=True)
    Path(storage_mount).mkdir(parents=True, exist_ok=True)

    ssh_opts = [
        "-o", "StrictHostKeyChecking=no",
        "-o", "reconnect",
        "-o", "ServerAliveInterval=15",
    ]
    if ssh_key:
        ssh_opts = ["-o", f"IdentityFile={ssh_key}"] + ssh_opts

    info(f"Mounting home via SSHFS...")
    subprocess.run(
        ["sshfs", "-p", str(ssh_port), f"{ssh_user}@{ip}:/data/data/com.termux/files/home",
         mount_point] + ssh_opts,
        stdout=NULL, stderr=NULL
    )

    info(f"Mounting storage via SSHFS...")
    subprocess.run(
        ["sshfs", "-p", str(ssh_port), f"{ssh_user}@{ip}:/storage/emulated/0",
         storage_mount] + ssh_opts,
        stdout=NULL, stderr=NULL
    )

    if is_mounted(mount_point):
        success(f"Mounted at {mount_point} and {storage_mount}")
        try:
            subprocess.run(["notify-send", "Phone mounted", f"{ip}"], stdout=NULL, stderr=NULL)
        except Exception:
            pass
        subprocess.Popen(["xdg-open", storage_mount], stdout=NULL, stderr=NULL)
    else:
        err("Mount failed.")


def cmd_tunnel(args):
    """Toggle DPI bypass SOCKS5 tunnel"""
    cfg = load_config()
    pid_file = cfg["socks_pid_file"]
    socks_port = cfg["socks_port"]

    def is_running():
        if os.path.exists(pid_file):
            try:
                with open(pid_file) as f:
                    pid = int(f.read().strip())
                os.kill(pid, 0)
                return True
            except (ProcessLookupError, ValueError, OSError):
                pass
        return False

    if args.action == "status":
        if is_running():
            try:
                with open(pid_file) as f:
                    pid = f.read().strip()
                success(f"Tunnel running (PID: {pid}, port {socks_port})")
            except (FileNotFoundError, ValueError):
                info("Tunnel status unavailable.")
        else:
            info("Tunnel not running.")
        return

    if args.action == "off" or (args.action == "toggle" and is_running()):
        if is_running():
            with open(pid_file) as f:
                pid = int(f.read().strip())
            try:
                os.kill(pid, signal.SIGTERM)
            except ProcessLookupError:
                pass
            if os.path.exists(pid_file):
                os.remove(pid_file)
            info("Tunnel stopped.")
            try:
                subprocess.run(["notify-send", "-u", "low", "DPI Tunnel", "Disconnected."],
                               stdout=NULL, stderr=NULL)
            except Exception:
                pass
        else:
            info("Not running.")
        return

    # Start tunnel
    conn = resolve_connection(cfg)
    ip = conn.ip
    if not ip:
        fatal("Could not detect phone IP.\nIs USB tethering or ethernet connected?")
    check_dep("ssh")
    cmd = ["ssh", "-D", str(socks_port), "-q", "-N",
           "-o", "StrictHostKeyChecking=no",
           "-o", "UserKnownHostsFile=/dev/null",
           "-o", "ServerAliveInterval=30",
           "-p", str(conn.ssh_port), f"{conn.ssh_user}@{ip}"]
    if conn.ssh_key:
        cmd.extend(["-i", conn.ssh_key])

    proc = subprocess.Popen(cmd, stdout=NULL, stderr=NULL)
    with open(pid_file, "w") as f:
        f.write(str(proc.pid))
    success(f"Tunnel started (PID: {proc.pid}, port {socks_port})")
    try:
        subprocess.run(["notify-send", "-u", "low", "DPI Tunnel", f"Connected via {ip}."],
                       stdout=NULL, stderr=NULL)
    except Exception:
        pass


