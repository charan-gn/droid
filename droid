def cmd_clip(args):
    """Clipboard sync push/pull"""
    cfg = load_config()
    serial = require_adb(cfg)

    if args.direction == "push":
        r = subprocess.run(["wl-paste"], capture_output=True, text=True, timeout=5)
        text = r.stdout.strip()
        if not text:
            err("Clipboard is empty.")
            return
        quoted = shlex.quote(text)
        r2 = subprocess.run(
            ["adb", "-s", serial, "shell",
             f"am broadcast -a clipper.set --es text {quoted}"],
            capture_output=True, timeout=5
        )
        if r2.returncode == 0:
            success(f"Clipboard pushed ({len(text)} chars) via Clipper broadcast.")
        else:
            err("Clipboard push failed.")
    else:
        try:
            r = subprocess.run(
                ["adb", "-s", serial, "shell",
                 "service call clipboard 2 2>/dev/null | grep -oP '(?<=0x).*?(?=\\s|$)'"],
                capture_output=True, text=True, timeout=5
            )
            if r.stdout.strip() and r.returncode == 0:
                hex_data = "".join(r.stdout.split())
                text = bytes.fromhex(hex_data).decode("utf-16le", errors="ignore").strip("\x00")
                if text:
                    subprocess.run(["wl-copy"], input=text.encode(), check=True)
                    success(f"Clipboard pulled ({len(text)} chars) via root method.")
                    return
        except Exception:
            pass
        r2 = subprocess.run(
            ["adb", "-s", serial, "shell", "am broadcast -a clipper.get"],
            capture_output=True, text=True, timeout=5
        )
        if "Result: " in r2.stdout:
            text = r2.stdout.split("Result: ")[-1].strip()
            subprocess.run(["wl-copy"], input=text.encode(), check=True)
            success(f"Clipboard pulled ({len(text)} chars) via Clipper broadcast.")
        else:
            err("Clipboard pull failed. Install Clipper app or ensure root access.")


