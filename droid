def _companion_shell(cfg, conn, serial):
    """Open interactive shell on companion device"""
    if conn.ssh_port and conn.ip:
        cmd = ["ssh", f"{conn.ssh_user}@{conn.ip}", "-p", str(conn.ssh_port)]
        if conn.ssh_key:
            cmd += ["-i", conn.ssh_key]
        if shutil.which("kitty"):
            subprocess.Popen(["kitty", "-e"] + cmd)
        else:
            subprocess.run(cmd)
    else:
        subprocess.run(["adb", "-s", serial, "shell"])


def _companion_exec(cfg, conn, serial, cmd_args):
    """Run a command on companion device and show output"""
    if not cmd_args:
        err("Usage: droid companion exec <command>")
        return
    cmd_str = " ".join(cmd_args)
    if conn.ssh_port and conn.ip:
        ssh_cmd = ["ssh", f"{conn.ssh_user}@{conn.ip}", "-p", str(conn.ssh_port)]
        if conn.ssh_key:
            ssh_cmd += ["-i", conn.ssh_key]
        ssh_cmd.append(cmd_str)
        r = subprocess.run(ssh_cmd, capture_output=True, text=True, timeout=30)
    else:
        r = subprocess.run(
            ["adb", "-s", serial, "shell", cmd_str],
            capture_output=True, text=True, timeout=30
        )
    out = (r.stdout + r.stderr).strip()
    if out:
        print(out)


def _companion_share(cfg, conn, serial, target):
    """Share resources between PC and companion device"""
    if target == "clip":
        # Clipboard sync
        r = subprocess.run(["adb", "-s", serial, "shell",
                            "echo $(input keyevent KEYCODE_WAKEUP 2>/dev/null); "
                            "am broadcast -a clipper.get 2>/dev/null; "
                            "sleep 0.5; input keyevent KEYCODE_SLEEP 2>/dev/null"],
                           capture_output=True, text=True, timeout=10)
        print(r.stdout.strip() or "Clipboard pull not supported via ADB directly.\nUse: droid clip push|pull")
    elif target == "dir":
        # Open file manager in mount directory
        mp = cfg.get("mount_point", "/mnt/phone")
        if Path(mp).is_mount():
            subprocess.Popen(["xdg-open", mp])
        else:
            err("Phone not mounted. Run: droid mount")
    elif target == "file":
        # Send file via KDE Connect or ADB
        subprocess.run([sys.argv[0], "kdeconnect", "send-file"], timeout=15)
    else:
        info("Targets: clip (clipboard), file (send file), dir (open mounted storage)")


def _companion_tunnel(cfg, conn, serial, action):
    """Manage network tunnel through companion device"""
    subprocess.run([sys.argv[0], "tunnel", action or "toggle"])


