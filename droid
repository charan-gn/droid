def cmd_devices(args):
    """List all connected ADB devices"""
    serials = _get_all_adb_serials()
    if RICH:
        _console = Console()
        if not serials:
            _console.print(Panel("[red]No ADB devices connected[/]", title="Devices", border_style="red"))
            return
        cfg = load_config()
        preferred = cfg.get("preferred_device", "")
        if not preferred and len(serials) == 1:
            preferred = serials[0]
        rows = []
        for s in serials:
            marker = "  ← active" if s == preferred else ""
            rows.append(("🔌", s, marker))
        t = Table(box=rich_box.SIMPLE, show_header=False)
        t.add_column(style="cyan", width=4)
        t.add_column(style="white")
        t.add_column(style="green")
        for icon, serial, marker in rows:
            t.add_row(icon, serial, marker)
        _console.print(Panel(t, title=f"ADB Devices ({len(serials)})", border_style="cyan"))
        return
    if not serials:
        err("No ADB devices connected.")
        return
    print(f"{BOLD}ADB Devices ({len(serials)}):{RESET}")
    cfg = load_config()
    preferred = cfg.get("preferred_device", "")
    if not preferred and len(serials) == 1:
        preferred = serials[0]
    for s in serials:
        marker = "  ← active" if s == preferred else ""
        print(f"  🔌  {s}{marker}")


def cmd_switch(args):
    """Switch active ADB device"""
    global _conn_cache
    serials = _get_all_adb_serials()
    if not serials:
        fatal("No ADB devices connected.")
    if len(serials) == 1:
        cfg = load_config()
        cfg["preferred_device"] = serials[0]
        DETECTED_FIELDS.discard("preferred_device")
        save_config(cfg)
        _conn_cache = None
        success(f"Active device: {serials[0]}")
        return
    chosen = _fzf_pick(serials, "Select ADB device")
    if chosen:
        cfg = load_config()
        cfg["preferred_device"] = chosen
        DETECTED_FIELDS.discard("preferred_device")
        save_config(cfg)
        _conn_cache = None
        success(f"Active device: {chosen}")


def cmd_ssh(args):
    """SSH into phone"""
    cfg = load_config()
    conn = resolve_connection(cfg)
    if not conn.ip:
        fatal("Could not detect phone IP.\nIs USB tethering or ethernet connected?")
    cmd = ["ssh", "-p", str(conn.ssh_port), f"{conn.ssh_user}@{conn.ip}",
           "-o", "StrictHostKeyChecking=no",
           "-o", "ServerAliveInterval=15"]
    if conn.ssh_key:
        cmd.extend(["-i", conn.ssh_key])
    r = subprocess.run(cmd)
    if r.returncode != 0:
        err(f"SSH exited with code {r.returncode}.")
        sys.exit(r.returncode)


def cmd_shell(args):
    """Interactive phone shell (SSH preferred, ADB fallback)"""
    cfg = load_config()
    conn = resolve_connection(cfg)
    if conn.ssh_ok:
        cmd = ["ssh", "-t", "-p", str(conn.ssh_port), f"{conn.ssh_user}@{conn.ip}",
               "-o", "StrictHostKeyChecking=no"]
        if conn.ssh_key:
            cmd.extend(["-i", conn.ssh_key])
        if args.cmd:
            cmd.append(args.cmd)
        subprocess.run(cmd)
    elif conn.adb_ok:
