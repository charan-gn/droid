    subprocess.run(["hyprctl", "dispatch", "workspace", str(workspace)],
                   stdout=NULL, stderr=NULL)
    try:
        proc.wait()
    except KeyboardInterrupt:
        proc.terminate()
    finally:
        subprocess.run(
            ["adb", "-s", serial, "shell", "cmd", "power",
             "set-fixed-performance-mode-enabled", "false"],
            stdout=NULL, stderr=NULL
        )


def _launch_app(args, cfg: dict, serial: str):
    """Android app launcher via fuzzel + scrcpy"""
    check_dep("fuzzel", "sudo pacman -S fuzzel")
    check_dep("scrcpy", "sudo pacman -S scrcpy")
    check_dep("jq", "sudo pacman -S jq")

    if args.pkg:
        target_pkg = args.pkg
        app_label = target_pkg.split(".")[-1]
    else:
        r = subprocess.run(
            ["adb", "-s", serial, "shell", "pm", "list", "packages", "-3"],
            capture_output=True, text=True, timeout=10
        )
        raw = r.stdout.strip().splitlines()
        apps = []
        for line in raw:
            pkg = line.replace("package:", "").strip()
            if pkg:
                label = pkg.split(".")[-1]
                apps.append((label, pkg))

        if not apps:
            err("No user apps found.")
            return

        display_lines = [f"{l}  [{p}]" for l, p in apps]
        fuzzel_in = "\n".join(display_lines)
        r2 = subprocess.run(
            ["fuzzel", "--dmenu", "--prompt", "Android App: "],
            input=fuzzel_in, capture_output=True, text=True
        )
        selection = r2.stdout.strip()
        if not selection:
            return

        target_pkg = None
        for line, (label, pkg) in zip(display_lines, apps):
            if line == selection:
                target_pkg = pkg
                break
        if not target_pkg:
            err("Could not resolve package.")
            return

        app_label = selection.split("  [")[0]
    info(f"Launching {app_label}...")

    if args.portrait:
        display_size = "1080x1920/420"
    else:
        try:
            mon = json.loads(subprocess.check_output(
                ["hyprctl", "-j", "monitors"], timeout=5).decode())
            focused = [m for m in mon if m.get("focused")][0]
            mon_w = focused.get("width", 1920)
            mon_h = focused.get("height", 1080)
            ws_id = 1
            try:
                aw = json.loads(subprocess.check_output(
                    ["hyprctl", "-j", "activewindow"], timeout=5).decode())
                ws_id = aw.get("workspace", {}).get("id", 1)
            except Exception:
                pass
            clients = json.loads(subprocess.check_output(
                ["hyprctl", "-j", "clients"], timeout=5).decode())
            tile_count = len([c for c in clients
                              if c.get("workspace", {}).get("id") == ws_id
                              and not c.get("floating")])
            tile_w = mon_w // (tile_count + 1) if tile_count > 0 else mon_w
            display_size = f"{tile_w}x{mon_h}/240"
        except Exception:
            display_size = "1920x1080/240"

    subprocess.Popen(
        ["scrcpy",
         f"--serial={serial}",
         f"--new-display={display_size}",
         f"--start-app={target_pkg}",
         f"--window-title=Android: {app_label}",
         "--audio-source=output"],
        stdout=NULL, stderr=NULL
    )


def _external_launch(args, cfg: dict, serial: str):
    """Launch app on external display ID (no scrcpy)"""
    check_dep("fuzzel", "sudo pacman -S fuzzel")
    r = subprocess.run(
        ["adb", "-s", serial, "shell", "dumpsys", "display"],
        capture_output=True, text=True, timeout=10
    )
    display_ids = set()
    for m in re.finditer(r"mDisplayId=(\d+)", r.stdout):
        did = int(m.group(1))
        if did != 0:
            display_ids.add(did)

    target_display = args.display_id
    if target_display is None:
        target_display = min(display_ids) if display_ids else 1

    r2 = subprocess.run(
        ["adb", "-s", serial, "shell", "pm", "list", "packages", "-3"],
        capture_output=True, text=True, timeout=10
    )
    apps = []
    for line in r2.stdout.strip().splitlines():
        pkg = line.replace("package:", "").strip()
        if pkg:
            label = pkg.split(".")[-1]
            apps.append((label, pkg))

    if not apps:
        err("No user apps found.")
        return

    display_lines = [f"{l}  [{p}]" for l, p in apps]
    fuzzel_in = "\n".join(display_lines)
    r3 = subprocess.run(
        ["fuzzel", "--dmenu", "--prompt", f"App on Display {target_display}: "],
        input=fuzzel_in, capture_output=True, text=True
    )
    selection = r3.stdout.strip()
    if not selection:
        return

    target_pkg = None
    for line, (label, pkg) in zip(display_lines, apps):
        if line == selection:
            target_pkg = pkg
            break
    if not target_pkg:
        err("Could not resolve package.")
        return

    activity = subprocess.run(
        ["adb", "-s", serial, "shell",
         f"cmd package resolve-activity --brief -c android.intent.category.LAUNCHER {target_pkg}"],
        capture_output=True, text=True, timeout=10
    )
    act_line = next((l.strip() for l in activity.stdout.splitlines() if "/" in l), None)

    if act_line:
        subprocess.run(
            ["adb", "-s", serial, "shell",
             "am", "start",
             f"--display={target_display}",
             "-n", act_line,
             "-f", "0x10200000"],
            stdout=NULL, stderr=NULL
        )
    else:
        subprocess.run(
            ["adb", "-s", serial, "shell",
             f"ANDROID_DATA=/data monkey --display {target_display} -p {target_pkg} -c android.intent.category.LAUNCHER 1"],
            stdout=NULL, stderr=NULL
        )
    success(f"Launched on display {target_display}.")


def _droidconnect(args, cfg: dict, serial: str):
    """Connect to DroidSpaces container"""
    droid_paths = [
        "/data/local/Droidspaces/bin/droidspaces",
        "/data/data/com.termux/files/usr/bin/droidspaces",
    ]
    droid_path = None
    for p in droid_paths:
        r = subprocess.run(["adb", "-s", serial, "shell", "test", "-f", p],
                           capture_output=True, timeout=5)
        if r.returncode == 0:
            droid_path = p
            break
    if not droid_path:
        fatal("DroidSpaces binary not found on device.")
    container = args.container or cfg.get("droid_container") or ""
    if not container:
        container = _detect_droid_container(serial) or ""
    if not container:
        r = subprocess.run(
            ["adb", "-s", serial, "shell", f"{droid_path} list"],
            capture_output=True, text=True, timeout=10
        )
        containers = [l.strip() for l in r.stdout.splitlines() if l.strip()]
        if not containers:
            fatal("No DroidSpaces containers found.")
        container = containers[0]
        info(f"Auto-detected container: {container}")

    droid_mode = _detect_droid_mode(serial)
    socat_port = 6001
    check_dep("socat", "sudo pacman -S socat")

    if not args.cmd and not args.x11:
        cmd = ["adb", "-s", serial, "exec-out", f"{droid_path} --name={container} enter"]
        subprocess.run(cmd)
        return

    if not args.x11:
        cmd = ["adb", "-s", serial, "exec-out",
               f"{droid_path} --name={container} run sh -c {shlex.quote(args.cmd)}"]
        subprocess.run(cmd)
        return

    # X11 mode
    if not subprocess.run(["pgrep", "-f", f"socat.*:{socat_port}.*X1"],
                          capture_output=True).stdout.strip():
        subprocess.Popen(
            ["socat", f"TCP-LISTEN:{socat_port},reuseaddr,fork",
             "UNIX-CONNECT:/tmp/.X11-unix/X1"],
            stdout=NULL, stderr=NULL
        )
        subprocess.run(["adb", "-s", serial, "reverse", f"tcp:{socat_port}", f"tcp:{socat_port}"],
                       stdout=NULL, stderr=NULL)

    subprocess.run(["adb", "-s", serial, "wait-for-device"],
                   stdout=NULL, stderr=NULL)

    shell_cmd = args.cmd or "bash"
    terminal = "kitty"
    for term in ["kitty", "ghostty", "alacritty", "foot", "wezterm", "konsole", "gnome-terminal"]:
        if shutil.which(term):
            terminal = term
            break
    term_cmd = [
        terminal, "--title", f"droidspaces - {container}",
        "-e", "adb", "-s", serial, "exec-out",
        f"{droid_path} --name={container} run env DISPLAY=:1 {shell_cmd}"
    ]
    if terminal in ("foot", "ghostty"):
        term_cmd = [
            terminal, "--title", f"droidspaces - {container}",
            "adb", "-s", serial, "exec-out",
            f"{droid_path} --name={container} run env DISPLAY=:1 {shell_cmd}"
        ]
    subprocess.run(term_cmd)


def _wiki(args, cfg: dict):
    """Kiwix offline Wikipedia server"""
    zim_dir = Path(cfg["kiwix_zim_dir"])
    port = cfg["kiwix_port"]
    log_file = Path("/tmp/kiwix-serve.log")

    check_dep("kiwix-serve", "Install kiwix-tools from kiwix.org")

    # Check if running
    r = subprocess.run(["ss", "-tulpn"], capture_output=True, text=True)
    if f":{port} " in r.stdout:
        if args.stop:
            subprocess.run(["fuser", "-k", f"{port}/tcp"], stdout=NULL, stderr=NULL)
            try:
                subprocess.run(["notify-send", "Kiwix", "Server Stopped"],
                               stdout=NULL, stderr=NULL)
            except Exception:
                pass
            success("Kiwix server stopped.")
            return
        info(f"Kiwix already running on port {port}.")
        return

    if args.stop:
        info("Not running.")
        return

    if not zim_dir.exists():
        err(f"ZIM directory not found: {zim_dir}")
        return

    zims = sorted(zim_dir.glob("*.zim"))
    if not zims:
        err(f"No .zim files in {zim_dir}")
        return

    laptop_ip = None
    try:
        iface = cfg.get("ssh_interface", "")
        if not iface:
            iface = "usb0"
            test = subprocess.run(["ip", "link", "show", iface], capture_output=True, timeout=3)
            if test.returncode != 0:
                iface = "eth0"
        r = subprocess.run(["ip", "addr", "show", iface],
                           capture_output=True, text=True)
        m = re.search(r"inet (\d+\.\d+\.\d+\.\d+)", r.stdout)
        if m:
            laptop_ip = m.group(1)
    except Exception:
        pass
    if not laptop_ip:
        try:
            laptop_ip = subprocess.check_output(["hostname", "-I"], timeout=5).decode().split()[0]
        except Exception:
            laptop_ip = "localhost"

    url = f"http://{laptop_ip}:{port}"
    proc = subprocess.Popen(
        ["kiwix-serve", "--port", str(port)] + [str(z) for z in zims],
        stdout=open(log_file, "w"), stderr=subprocess.STDOUT
    )

    time.sleep(2)
    r2 = subprocess.run(["ss", "-tulpn"], capture_output=True, text=True)
    if f":{port} " in r2.stdout:
        try:
            subprocess.run(["wl-copy"], input=url.encode(), check=True)
        except Exception:
            pass
        success(f"Kiwix online: {url}")
        try:
            subprocess.run(["notify-send", "Kiwix Online",
                            f"Library: {url}\nCopied to clipboard."],
                           stdout=NULL, stderr=NULL)
        except Exception:
            pass
    else:
        err("Kiwix server failed to start.")
        if log_file.exists():
            with open(log_file) as f:
                print(f.read())


def _music(args, cfg: dict):
    """YouTube downloader with folder picker"""
    base_dir = Path(cfg.get("music_base_dir", str(Path.home() / "Music")))
    base_dir.mkdir(parents=True, exist_ok=True)
    state_dir = Path.home() / ".music_last_dir"
    state_mode = Path.home() / ".music_last_mode"

    check_dep("yt-dlp", "sudo pacman -S yt-dlp")

    default_dir = None
    if state_dir.exists():
        d = state_dir.read_text().strip()
        if (base_dir / d).is_dir():
            default_dir = d

    default_mode = 1
    if state_mode.exists():
        try:
            default_mode = int(state_mode.read_text().strip())
        except ValueError:
            pass

    # List subfolders
    subdirs = sorted(
        d.name for d in base_dir.iterdir() if d.is_dir()
    )

    def pick_folder():
        nonlocal default_dir
        print(f"Select folder in {base_dir}:")
        print("----------------------------------------")
        print("  [0]  <Create new folder>")
        for i, name in enumerate(subdirs, 1):
            marker = " (Current)" if name == default_dir else ""
            print(f"  [{i}]  {name}{marker}")
        print("----------------------------------------")
        default_idx = subdirs.index(default_dir) + 1 if default_dir in subdirs else 0
        prompt = f"Choose [default: {default_idx}]: " if default_dir else "Choose [default: 0]: "
        choice = input(prompt).strip()
        if not choice:
            choice = str(default_idx)
        if choice == "0" or not choice:
            name = input("Enter new folder name: ").strip()
            if not name:
                err("Name cannot be empty.")
                return None
            (base_dir / name).mkdir(exist_ok=True)
            return name
        try:
            idx = int(choice) - 1
            if 0 <= idx < len(subdirs):
                return subdirs[idx]
        except ValueError:
            pass
        err("Invalid selection.")
        return None

    if args.url:
        folder = args.dir or default_dir
        if not folder:
            folder = pick_folder()
            if not folder:
                return
        selected_dir = base_dir / folder
        url = args.url
        mode = args.mode or default_mode
    else:
        folder = pick_folder()
        if not folder:
            return
        selected_dir = base_dir / folder
        url = input("Enter YouTube URL: ").strip()
        if not url:
            return
        print(f"\nDownload mode:")
        print("  [1]  Audio only (opus)")
        print("  [2]  Audio + Video (1080p60)")
        mode_label = "Audio" if default_mode == 1 else "Video"
        m = input(f"Choose [default: {default_mode} ({mode_label})]: ").strip()
        if m:
            try:
                mode = int(m)
            except ValueError:
                err("Invalid input, using default.")
                mode = default_mode
        else:
            mode = default_mode

    state_dir.write_text(folder)
    state_mode.write_text(str(mode))

    os.chdir(str(selected_dir))

    if mode == 1:
        info("Downloading audio...")
        subprocess.run(
            ["yt-dlp", "-f", "ba", "-x", "--audio-format", "opus",
             "--embed-thumbnail", "--embed-metadata",
             "--write-subs", "--write-auto-subs", "--convert-subs", "lrc",
             "-o", "%(title)s.%(ext)s", url]
        )
        success("Done.")
    else:
        info("Downloading 1080p60 video...")
        subprocess.run(
            ["yt-dlp",
             "-f", "bestvideo[height<=1080][fps<=60]+bestaudio",
             "--merge-output-format", "mkv",
             "--embed-thumbnail", "--embed-metadata",
             "--write-subs", "--write-auto-subs",
