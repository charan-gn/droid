def cmd_companion(args):
    """Unified companion interface — offload tasks to your phone"""
    cfg = load_config()
    conn = resolve_connection(cfg)
    serial = require_adb(cfg)

    action = args.companion_action or "status"

    if action == "status":
        _companion_status(cfg, conn, serial)
    elif action == "shell":
        _companion_shell(cfg, conn, serial)
    elif action == "exec":
        _companion_exec(cfg, conn, serial, args.cmd)
    elif action == "share":
        _companion_share(cfg, conn, serial, args.share_target)
    elif action == "tunnel":
        _companion_tunnel(cfg, conn, serial, args.tunnel_action)


def _companion_status(cfg, conn, serial):
    """Show companion health — connection, resources, services"""
    kwargs = dict(capture_output=True, text=True, timeout=5)

    r_batt = subprocess.run(["adb", "-s", serial, "shell",
                             "dumpsys battery | grep level:"], **kwargs)
    batt = '?'
    for line in r_batt.stdout.splitlines():
        if 'level:' in line:
            batt = line.split(':')[1].strip() + '%'

    r_ip = subprocess.run(["adb", "-s", serial, "shell",
                           "ip -4 a show wlan0 2>/dev/null | grep inet"], **kwargs)
    ip = '?'
    for line in r_ip.stdout.splitlines():
        parts = line.strip().split()
        if parts and len(parts) > 1:
            ip = parts[1].split('/')[0]

    r_df = subprocess.run(["adb", "-s", serial, "shell",
                           "df -h /data 2>/dev/null | tail -1"], **kwargs)
    storage = '?'
    parts = r_df.stdout.strip().split()
    if len(parts) >= 4:
        storage = f"{parts[2]} used / {parts[3]} total"

    services = []
    if conn.ssh_port:
        services.append(f"SSH :{conn.ssh_port}")
    r_ss = subprocess.run(["ss", "-tulpn"], capture_output=True, text=True)
    if ":1080" in r_ss.stdout:
        services.append("SOCKS5 :1080")

    r_model = subprocess.run(["adb", "-s", serial, "shell",
                              "getprop ro.product.model"], **kwargs)
    model = r_model.stdout.strip() or '?'

    r_sdk = subprocess.run(["adb", "-s", serial, "shell",
                            "getprop ro.build.version.sdk"], **kwargs)
    sdk = r_sdk.stdout.strip() or '?'
