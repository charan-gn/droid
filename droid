def _run_kvm(cfg: dict):
    """Seamless KVM implementation (from 1.py)"""
    WINDOW_TITLE = "Android-Input"
    LOG = "/tmp/scrcpy-kvm.log"
    EDGE_DEBOUNCE = 3
    POLL_INTERVAL = 0.016

    def notify(icon, title, msg, urgency="normal"):
        try:
            subprocess.Popen(
                ["notify-send", "-u", urgency, "-a", "Android KVM", title, f"{icon} {msg}"],
                stdout=NULL, stderr=NULL
            )
        except FileNotFoundError:
            pass

    check_dep("ydotool", "sudo pacman -S ydotool")
    status = subprocess.run(
        ["systemctl", "--user", "is-active", "ydotool"],
        capture_output=True, text=True
    ).stdout.strip()
    if status != "active":
        fatal("ydotool daemon is not active.\nRun: systemctl --user enable --now ydotool", "Android KVM")

    _rctrl_event = threading.Event()
    _stop_flag = threading.Event()

    def _rctrl_listener(stop_flag):
        try:
            import evdev
            from evdev import ecodes
        except ImportError:
            info("python-evdev not available, RCtrl not monitored")
            return
        KEY_RIGHTCTRL = ecodes.KEY_RIGHTCTRL

        def open_keyboards():
            boards = []
            for path in evdev.list_devices():
                try:
                    dev = evdev.InputDevice(path)
                    cap = dev.capabilities()
                    if ecodes.EV_KEY in cap and KEY_RIGHTCTRL in cap[ecodes.EV_KEY]:
                        boards.append(dev)
                except Exception:
                    pass
            return boards

        keyboards = open_keyboards()
        if not keyboards:
            return
        import selectors
        sel = selectors.DefaultSelector()
        for kb in keyboards:
            sel.register(kb, selectors.EVENT_READ)
        while not stop_flag.is_set():
            ready = sel.select(timeout=0.5)
            for key, _ in ready:
                dev = key.fileobj
                try:
                    for event in dev.read():
                        if (event.type == ecodes.EV_KEY
                                and event.code == KEY_RIGHTCTRL
                                and event.value == 1):
                            _rctrl_event.set()
                except Exception:
                    pass
        sel.close()
        for kb in keyboards:
            try:
                kb.close()
            except Exception:
                pass

    def hyprctl_request(cmd):
        sig = os.environ.get("HYPRLAND_INSTANCE_SIGNATURE")
        if sig:
            xdg = os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}")
            for p in [f"{xdg}/hypr/{sig}/.socket.sock", f"/tmp/hypr/{sig}/.socket.sock"]:
                if os.path.exists(p):
                    try:
                        s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
                        s.settimeout(3.0)
                        s.connect(p)
                        s.sendall(f"-j/{cmd}".encode())
                        chunks = []
                        while True:
                            data = s.recv(8192)
                            if not data:
                                break
                            chunks.append(data)
                        s.close()
                        return b"".join(chunks).decode()
                    except socket.timeout:
                        s.close()
                    except Exception:
                        pass
        return subprocess.check_output(["hyprctl", "-j", cmd], timeout=5).decode()

    def get_active_workspace():
        try:
            return json.loads(hyprctl_request("activeworkspace")).get("id", 1)
        except Exception:
            return 1

    def get_monitors():
        try:
            return json.loads(hyprctl_request("monitors"))
        except Exception:
            return []

    _mon_cache = {"data": [], "ts": 0.0}

    def cached_monitors():
        now = time.monotonic()
        if not _mon_cache["data"] or now - _mon_cache["ts"] > 30.0:
            _mon_cache["data"] = get_monitors()
            _mon_cache["ts"] = now
        return _mon_cache["data"]

    def get_focused_monitor_bounds():
        for m in cached_monitors():
            if m.get("focused"):
                scale = m.get("scale", 1.0)
                return int(m["width"] / scale), int(m["height"] / scale), int(m["x"]), int(m["y"])
        return 1920, 1080, 0, 0

    def get_right_edge():
        mons = cached_monitors()
        if not mons:
            return 1920
        return max(m["x"] + int(m["width"] / m.get("scale", 1.0)) for m in mons)

    def get_cursor_pos():
        try:
            data = json.loads(hyprctl_request("cursorpos"))
            return int(data.get("x", 0)), int(data.get("y", 0))
        except Exception:
            try:
                out = subprocess.check_output(["hyprctl", "cursorpos"], timeout=5).decode()
                x_str, y_str = out.strip().split(",")
                return int(x_str.strip()), int(y_str.strip())
            except Exception:
                return 0, 0

    conn = resolve_connection(cfg)
    if not conn.adb_ok:
        if cfg.get("adb_connect_auto", True) and conn.ip:
            subprocess.run(["adb", "connect", f"{conn.ip}:5555"],
                           capture_output=True, timeout=5)
            conn2 = resolve_connection(cfg)
            if not conn2.adb_ok:
                fatal("No ADB device found.", "Android KVM")
            serial = conn2.adb_serial
        else:
            fatal("No ADB device found.", "Android KVM")
    else:
        serial = conn.adb_serial

    def setup_hyprland_rules():
        title_match = f"title:^({WINDOW_TITLE})$"
        class_match = "class:^(scrcpy)$"
        for m in (title_match, class_match):
            subprocess.run(["hyprctl", "keyword", "windowrule",
                            f"noanim,{m}"], stdout=NULL, stderr=NULL)
            subprocess.run(["hyprctl", "keyword", "windowrule",
                            f"opacity 0.0 override 0.0 override,{m}"], stdout=NULL, stderr=NULL)
        for rule in [
            f"noborder,{title_match}",
            f"noblur,{title_match}",
            f"noshadow,{title_match}",
            f"move -9999 -9999,{title_match}",
            f"move -9999 -9999,{class_match}",
            f"size 200 200,{title_match}",
            f"float,{title_match}",
            f"workspace special:kvm silent,{title_match}",
            f"workspace special:kvm silent,{class_match}",
            f"suppressevent activate activatefocus,{title_match}",
            f"suppressevent activate activatefocus,{class_match}",
            f"noinitialfocus,{title_match}",
            f"noinitialfocus,{class_match}",
        ]:
            subprocess.run(["hyprctl", "keyword", "windowrule", rule],
                           stdout=NULL, stderr=NULL)

    setup_hyprland_rules()
    cmd = [
        "scrcpy",
        f"--serial={serial}",
        "--no-video",
        "--no-audio",
        "--keyboard=sdk",
        "--mouse=uhid",
        "--mouse-bind=++++:++++",
        "--stay-awake",
        f"--window-title={WINDOW_TITLE}",
        "--shortcut-mod=rctrl",
    ]
    log_file = open(LOG, "w")
    scrcpy_proc = subprocess.Popen(cmd, stdout=log_file, stderr=log_file)
    time.sleep(1.5)
    notify("*", "Android KVM", "Seamless KVM active! Move mouse to right edge.", "normal")

    listener_thread = threading.Thread(
        target=_rctrl_listener, args=(_stop_flag,), daemon=True
    )
    listener_thread.start()

    is_on_android = False
    right_edge = get_right_edge()
    EDGE_TRIGGER = max(right_edge - 2, 0)
    edge_count = 0

    try:
        while scrcpy_proc.poll() is None:
            x, y = get_cursor_pos()
            if not is_on_android:
                if x >= EDGE_TRIGGER:
                    edge_count += 1
                    if edge_count >= EDGE_DEBOUNCE:
                        is_on_android = True
                        edge_count = 0
                        _rctrl_event.clear()
                        notify("*", "Android KVM", "Switched to Android! (RCtrl to return)", "low")
                        active_ws = get_active_workspace()
                        w, h, mx, my = get_focused_monitor_bounds()
                        batch = (
                            f"dispatch movetoworkspacesilent {active_ws},title:^({WINDOW_TITLE})$ ; "
                            f"dispatch focuswindow title:^({WINDOW_TITLE})$ ; "
                            f"dispatch movecursor {mx + w // 2} {my + h // 2}"
                        )
                        subprocess.run(["hyprctl", "--batch", batch], stdout=NULL, stderr=NULL)
                        time.sleep(0.04)
                        subprocess.run(["ydotool", "click", "0xC0"], stdout=NULL, stderr=NULL)
                else:
                    edge_count = 0
            elif _rctrl_event.is_set():
                _rctrl_event.clear()
                is_on_android = False
                edge_count = 0
                subprocess.run(
                    ["hyprctl", "dispatch", "movetoworkspacesilent",
                     f"special:kvm,title:^({WINDOW_TITLE})$"],
                    stdout=NULL, stderr=NULL
                )
                notify("*", "Android KVM", "Returned to PC (RCtrl)", "low")
            elif is_on_android:
                w, h, mx, my = get_focused_monitor_bounds()
                if x < (mx + w // 2) - 250:
                    is_on_android = False
                    edge_count = 0
                    subprocess.run(
                        ["hyprctl", "dispatch", "movetoworkspacesilent",
                         f"special:kvm,title:^({WINDOW_TITLE})$"],
                        stdout=NULL, stderr=NULL
                    )
                    notify("*", "Android KVM", "Returned to PC", "low")
            time.sleep(POLL_INTERVAL)
    except KeyboardInterrupt:
        pass
    finally:
        _stop_flag.set()
        scrcpy_proc.terminate()
        log_file.close()
        notify("*", "Android KVM", "Session ended cleanly.", "low")


def _app_local(serial: str, cfg: dict):
    APK_DIR = cfg["apk_dir"]
    check_dep("adb")
    files = sorted(Path(APK_DIR).glob("*.apk"))
    files += sorted(Path(APK_DIR).glob("*.xapk"))
    files += sorted(Path(APK_DIR).glob("*.apkm"))
    if not files:
        err(f"No packages found in {APK_DIR}")
        return
    choice = _fzf_pick([f.name for f in files], "Select APK")
    if not choice:
        return
    target = next((f for f in files if f.name == choice), None)
    if target:
        _install_apk(serial, str(target), APK_DIR)


def _app_management(args, cfg: dict, serial: str):
    APK_DIR = cfg["apk_dir"]
    Path(APK_DIR).mkdir(parents=True, exist_ok=True)

    if args.subcommand is None:
        info("Usage: droid app local | install <name> | uninstall <name> | list [filter]")
        return

    if args.subcommand == "local":
        _app_local(serial, cfg)

    elif args.subcommand in ("install", "search"):
        query = " ".join(args.query) if args.query else ""
        if not query:
            _app_local(serial, cfg)
            return
        check_dep("apkeep", "cargo install apkeep")
        check_dep("python3")
        results = _search_play_store(query)
        if not results:
            err("No apps found.")
            return
        selected = _fzf_pick([f"{name}  [{pkg}]" for name, pkg in results], "Select app")
        if not selected:
            return
        selected = selected.split("  [")[-1].rstrip("]")
        info(f"Downloading {selected}...")
        r = subprocess.run(
            ["apkeep", "-a", selected, "-d", "apk-pure", APK_DIR],
            capture_output=True, text=True
        )
        if r.returncode != 0:
            err("Download failed.")
            return
        dl = list(Path(APK_DIR).glob(f"{selected}*.apk"))
        dl += list(Path(APK_DIR).glob(f"{selected}*.xapk"))
        dl += list(Path(APK_DIR).glob(f"{selected}*.apkm"))
        if not dl:
            dl = sorted(Path(APK_DIR).iterdir(), key=os.path.getmtime)[-1:]
        if dl:
            _install_apk(serial, str(dl[0]), APK_DIR)
        else:
            err("Could not find downloaded file.")

    elif args.subcommand == "uninstall":
        query = " ".join(args.query) if args.query else ""
        if not query:
            err("Specify a package name or search term.")
            return
        r = subprocess.run(
            ["adb", "-s", serial, "shell", "pm", "list", "packages"],
            capture_output=True, text=True, timeout=10
        )
        pkgs = [l.replace("package:", "").strip() for l in r.stdout.splitlines()
                if l.startswith("package:")]
        matches = [p for p in pkgs if query.lower() in p.lower()]
        if not matches:
            err(f"No packages match '{query}'")
            return
        if len(matches) == 1:
            selected = matches[0]
        else:
            selected = _fzf_pick(matches, "Select package to uninstall")
            if not selected:
                return
        r = subprocess.run(
            ["adb", "-s", serial, "shell", "pm", "uninstall", selected],
            capture_output=True, text=True
        )
        if "Success" in r.stdout:
            success(f"{selected} uninstalled.")
        else:
            r2 = subprocess.run(
                ["adb", "-s", serial, "shell", "pm", "uninstall", "--user", "0", selected],
                capture_output=True, text=True
            )
            if "Success" in r2.stdout:
                success(f"{selected} uninstalled (system app).")
            else:
                err(f"Could not uninstall {selected}.")

    elif args.subcommand == "list":
        filter_str = " ".join(args.query) if args.query else ""
        r = subprocess.run(
            ["adb", "-s", serial, "shell", "pm", "list", "packages"],
            capture_output=True, text=True, timeout=10
        )
        pkgs = [l.replace("package:", "").strip() for l in r.stdout.splitlines()
                if l.startswith("package:")]
        if filter_str:
            pkgs = [p for p in pkgs if filter_str.lower() in p.lower()]
        pkgs.sort()
        print(f"{BOLD}Packages ({len(pkgs)}):{RESET}")
        for p in pkgs:
            print(f"  {DIM}\u2022{RESET} {p}")


def _search_play_store(query: str) -> List[Tuple[str, str]]:
    import urllib.request, urllib.parse
    from concurrent.futures import ThreadPoolExecutor

    encoded = urllib.parse.quote(query)
    UA = "Mozilla/5.0 (X11; Linux x86_64; rv:124.0) Gecko/20100101 Firefox/124.0"

    def fetch(url):
        req = urllib.request.Request(url, headers={"User-Agent": UA})
        return urllib.request.urlopen(req, timeout=10).read().decode("utf-8", errors="ignore")

    try:
        html = fetch(f"https://play.google.com/store/search?q={encoded}&c=apps&hl=en_US")
    except Exception:
        return []

    packages, seen = [], set()
    for pkg in re.findall(r"details\?id=([a-zA-Z][a-zA-Z0-9_.]+)", html):
        if "." in pkg and pkg not in seen:
            seen.add(pkg)
            packages.append(pkg)
        if len(packages) >= 8:
            break

    def get_name(pkg):
        try:
            h = fetch(f"https://play.google.com/store/apps/details?id={pkg}&hl=en_US")
            m = re.search(r"<title>(.+?) - Apps on Google Play</title>", h)
            if m:
                return pkg, m.group(1).strip()
        except Exception:
            pass
        return pkg, pkg

    with ThreadPoolExecutor(max_workers=6) as ex:
        return list(ex.map(get_name, packages))


def _install_apk(serial: str, target: str, apk_dir: str):
    path = Path(target)
    if path.suffix == ".apk":
        info(f"Installing {path.name}...")
        r = subprocess.run(["adb", "-s", serial, "install", "-r", str(path)],
                           capture_output=True, text=True)
        if r.returncode == 0:
            success(f"{path.name} installed.")
        else:
            err(f"Install failed: {r.stderr.strip()}")
    elif path.suffix in (".xapk", ".apkm"):
        info(f"Extracting {path.name}...")
        check_dep("unzip", "sudo pacman -S unzip")
        tmp = Path(apk_dir) / f".tmp_extract_{os.getpid()}"
        shutil.rmtree(tmp, ignore_errors=True)
        tmp.mkdir(parents=True)
        r = subprocess.run(["unzip", "-q", str(path), "-d", str(tmp)], capture_output=True)
        if r.returncode != 0:
            err(f"Failed to extract {path.name}: {r.stderr.strip()}")
            shutil.rmtree(tmp, ignore_errors=True)
            return
        apks = sorted(tmp.rglob("*.apk"))
        if not apks:
            err("No APKs inside archive.")
            shutil.rmtree(tmp, ignore_errors=True)
            return
        info(f"Installing {len(apks)} split APK(s)...")
        cmd = ["adb", "-s", serial, "install-multiple", "-r"] + [str(a) for a in apks]
        r = subprocess.run(cmd, capture_output=True, text=True)
        if r.returncode == 0:
            success(f"{path.name} installed.")
        else:
            err(f"Split install failed: {r.stderr.strip()}")
        shutil.rmtree(tmp, ignore_errors=True)
    else:
        err(f"Unsupported: {path.suffix}")


def _module_management(args, cfg: dict, serial: str):
    MODULES_DIR = Path(cfg["modules_dir"])
    MODULES_DIR.mkdir(parents=True, exist_ok=True)

    def check_root():
        r = subprocess.run(
            ["adb", "-s", serial, "shell", "su -c id"],
            capture_output=True, text=True, timeout=5
        )
        if "uid=0" not in r.stdout:
            fatal("Root required.\nMake sure ADB shell root is granted in Magisk.")

    def get_modules():
        r = subprocess.run(
            ["adb", "-s", serial, "shell", "su -c 'ls /data/adb/modules/'"],
            capture_output=True, text=True, timeout=10
        )
        return [m.strip() for m in r.stdout.splitlines() if m.strip()]

    if args.module_subcommand == "list":
        check_root()
        mods = get_modules()
        if not mods:
            info("No modules or Magisk not installed.")
            return
        for mod in mods:
            r = subprocess.run(
                ["adb", "-s", serial, "shell",
                 f"su -c 'cat /data/adb/modules/{mod}/module.prop 2>/dev/null | grep ^name='"],
                capture_output=True, text=True, timeout=5
            )
            name = r.stdout.replace("name=", "").strip()
            label = f"{name} ({mod})" if name else mod
            print(f"  {DIM}\u2022{RESET} {label}")

    elif args.module_subcommand == "remove":
        check_root()
        mods = get_modules()
        if not mods:
            err("No modules found.")
            return
        selected = _fzf_pick(mods, "Select module to remove")
        if not selected:
            return
        subprocess.run(
            ["adb", "-s", serial, "shell",
             f"su -c 'touch /data/adb/modules/{selected}/remove'"],
            stdout=NULL, stderr=NULL
        )
        success(f"{selected} marked for removal (reboot to apply).")

    else:  # flash
        check_root()
        zips = sorted(MODULES_DIR.glob("*.zip"))
        if not zips:
            err(f"No .zip files in {MODULES_DIR}")
            return
        choice = _fzf_pick([z.name for z in zips], "Select module zip")
        if not choice:
            return
        target = str(MODULES_DIR / choice)
        fname = choice
        remote = f"/sdcard/Download/{fname}"
        info(f"Pushing {fname}...")
        subprocess.run(["adb", "-s", serial, "push", target, remote],
                       stdout=NULL, stderr=NULL)
        info("Flashing module...")
        r = subprocess.run(
            ["adb", "-s", serial, "shell", f"su -c 'magisk --install-module \"{remote}\"'"],
            capture_output=True, text=True, timeout=60
        )
        print(r.stdout)
        subprocess.run(
            ["adb", "-s", serial, "shell", f"su -c 'rm -f \"{remote}\"'"],
            stdout=NULL, stderr=NULL
        )
        if r.returncode == 0:
            success(f"{fname} flashed.")
            confirm = input("  Reboot now? [y/N] ").strip().lower()
            if confirm == "y":
                subprocess.run(["adb", "-s", serial, "reboot"], stdout=NULL, stderr=NULL)
        else:
            err("Flash failed.")


def _debloat(args, cfg: dict, serial: str):
    profile_name = args.profile or cfg.get("default_debloat_profile", "generic")
    profiles = cfg.get("debloat_profiles", {})
    profile = profiles.get(profile_name, profiles.get("generic", {}))

    if args.list_profiles:
        bold("Available debloat profiles:")
        for name in profiles:
            marker = " (default)" if name == cfg.get("default_debloat_profile") else ""
            print(f"  {DIM}\u2022{RESET} {name}{marker}")
        return

    if args.list_packages:
        bold(f"Packages in profile '{profile_name}':")
        for category, pkgs in profile.items():
            if pkgs:
                print(f"\n  {BOLD}{category}:{RESET}")
                for p in pkgs:
                    print(f"    {DIM}\u2022{RESET} {p}")
        return

    all_pkgs = []
    for cat, pkgs in profile.items():
        all_pkgs.extend(pkgs)

    if not all_pkgs:
        err(f"No packages defined in profile '{profile_name}'.")
        return

    print(f"{BOLD}Debloating with profile '{profile_name}' ({len(all_pkgs)} packages){RESET}\n")

    for pkg in all_pkgs:
        r = subprocess.run(
            ["adb", "-s", serial, "shell", "pm", "uninstall", "-k", "--user", "0", pkg],
            capture_output=True, text=True, timeout=10
        )
        status = "OK" if "Success" in (r.stdout + r.stderr) else "FAILED"
        color = GREEN if status == "OK" else RED
        print(f"  {color}[{status}]{RESET} {pkg}")

    bold("\nDone. Recommend reboot: adb reboot")


def _mirror(args, cfg: dict, serial: str):
    check_dep("scrcpy", "sudo pacman -S scrcpy")

    pkill = subprocess.run(["pkill", "-f", "scrcpy.*DROID_MIRROR"],
                           stdout=NULL, stderr=NULL)
    title = "DROID_MIRROR"
    workspace = args.workspace or 2
    bitrate = args.bitrate or "4M"

    subprocess.run(["hyprctl", "keyword", "windowrule", f"workspace {workspace},title:^({title})$"],
                   stdout=NULL, stderr=NULL)
    subprocess.run(["hyprctl", "keyword", "windowrule", f"fullscreen 2,title:^({title})$"],
                   stdout=NULL, stderr=NULL)
    if bitrate == "8M":
        subprocess.run(["hyprctl", "keyword", "windowrule", f"border_size 0,title:^({title})$"],
                       stdout=NULL, stderr=NULL)
        subprocess.run(["hyprctl", "keyword", "windowrule", f"rounding 0,title:^({title})$"],
                       stdout=NULL, stderr=NULL)
        subprocess.run(["hyprctl", "keyword", "windowrule", f"noanim,title:^({title})$"],
                       stdout=NULL, stderr=NULL)

    subprocess.run(
        ["adb", "-s", serial, "shell", "cmd", "power",
         "set-fixed-performance-mode-enabled", "true"],
        stdout=NULL, stderr=NULL
    )
    for setting in ["window_animation_scale", "transition_animation_scale", "animator_duration_scale"]:
        subprocess.run(
            ["adb", "-s", serial, "shell", "settings", "put", "global", setting, "0"],
            stdout=NULL, stderr=NULL
        )

    cmd = [
        "scrcpy", "-s", serial,
        "--new-display=1920x1080/284",
        "--video-codec=h264",
        f"--video-bit-rate={bitrate}",
        "--max-fps=60",
        "--keyboard=uhid",
        "--video-buffer=0",
        "--no-audio",
        "--window-borderless",
        "--turn-screen-off",
        "--no-clipboard-autosync",
        "--fullscreen",
        f"--window-title={title}",
    ]
    env = os.environ.copy()
    env["SDL_VIDEODRIVER"] = "wayland"
    proc = subprocess.Popen(cmd, env=env, stdout=NULL, stderr=NULL)
