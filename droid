                "app": lambda: self._adb_cmd("app", "list"),
                "modules": lambda: self._adb_cmd("modules", "list"),
                "debloat": lambda: self._adb_cmd("debloat"),
                "wiki": lambda: self._run_cmd(["kitty", "-e", sys.argv[0], "wiki"]),
                "clip": lambda: self._adb_cmd("clip", "pull"),
                "droidconnect": lambda: self._adb_cmd("droidconnect"),
                "kdeconnect": lambda: self._run_cmd(["kitty", "-e", sys.argv[0], "kdeconnect", "list"]),
                "home": lambda: self._run_cmd([sys.argv[0], "home"]),
                "device": lambda: self._adb_cmd("device"),
                "host": lambda: self._run_cmd(["kitty", "-e", sys.argv[0], "host"]),
                "switch": lambda: self._run_cmd(["kitty", "-e", sys.argv[0], "switch"]),
                "devices": lambda: self._run_cmd(["kitty", "-e", sys.argv[0], "devices"]),
                "tunnel": lambda: self._run_cmd(["kitty", "-e", sys.argv[0], "tunnel", "toggle"]),
                "refresh": self._update_stats,
                "quit": self.exit,
            }
            action = actions.get(event.button.id)
            if action:
                action()

        def action_refresh(self):
            self._update_stats()

        def _term_cmd(self, subcmd, *args):
            return ["kitty", "-e", sys.argv[0], subcmd] + list(args)

        def action_ssh(self): self._adb_cmd("ssh")
        def action_shell(self): self._adb_cmd("shell")
        def action_mount(self): self._adb_cmd("mount")
        def action_tunnel(self): self._run_cmd(self._term_cmd("tunnel", "toggle"))
