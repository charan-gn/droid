def load_config() -> dict:
    cfg = DEFAULT_CONFIG.copy()
    if CONFIG_FILE.exists():
        try:
            with open(CONFIG_FILE) as f:
                user_cfg = json.load(f)
            cfg.update(user_cfg)
        except (json.JSONDecodeError, OSError):
            pass
    return cfg


def save_config(cfg: dict):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    with open(CONFIG_FILE, "w") as f:
        json.dump(cfg, f, indent=2)

def config_get(key: str, default=None):
    return load_config().get(key, default)

# ── Device Discovery ──────────────────────────────────────────────────────────

@dataclass
class PhoneConn:
    ip: str = ""
    adb_serial: str = ""
    ssh_port: int = 8022
    ssh_user: str = ""
    ssh_key: Optional[str] = None
    iface: str = ""
    adb_ok: bool = False
    ssh_ok: bool = False

_conn_cache: Optional[PhoneConn] = None
_conn_cache_ts: float = 0.0
CONN_CACHE_TTL: float = 30.0


def _iter_wired_ifaces():
    try:
        r = subprocess.run(["ip", "-4", "addr", "show"],
                           capture_output=True, text=True, timeout=5)
        for line in r.stdout.splitlines():
            m = re.match(r"^\d+:\s+(\S+):", line)
            if m:
                iface = m.group(1).split("@")[0]
                if any(iface.startswith(p) for p in ("usb", "enp", "eth", "wlan")):
                    yield iface
    except Exception:
        pass


def _probe_ssh_port(ip: str, ports: List[int] = (8022, 2222)) -> int:
    for port in ports:
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            s.settimeout(1.0)
            result = s.connect_ex((ip, port))
            s.close()
            if result == 0:
                return port
        except Exception:
            pass
    return ports[0]


def detect_ssh_key() -> Optional[str]:
    ssh_dir = Path.home() / ".ssh"
    if ssh_dir.exists():
        for keyfile in sorted(ssh_dir.glob("id_*")):
            name = keyfile.name
            if not name.endswith(".pub") and keyfile.is_file() and name != "config":
                return str(keyfile)
    return None


def _detect_droid_container(serial: str) -> Optional[str]:
    droid_paths = [
        "/data/local/Droidspaces/bin/droidspaces",
        "/data/data/com.termux/files/usr/bin/droidspaces",
    ]
    droid_path = None
    for p in droid_paths:
        r = subprocess.run(["adb", "-s", serial, "shell", "test", "-f", p],
                           capture_output=True, timeout=5)
        if r.returncode == 0:
            droid_path = p
            break
    if droid_path:
        r = subprocess.run(
            ["adb", "-s", serial, "shell", f"{droid_path} list"],
            capture_output=True, text=True, timeout=10
        )
        containers = [l.strip() for l in r.stdout.splitlines() if l.strip()]
        if containers:
            return containers[0]
    for rootfs_dir in [
        "/data/local/Droidspaces/installed-rootfs/",
        "/data/local/Droidspaces/containers/",
        "/data/user/0/app.phonereality.droidspaces/files/rootfs/",
    ]:
        r = subprocess.run(
            ["adb", "-s", serial, "shell", f"ls {rootfs_dir} 2>/dev/null"],
            capture_output=True, text=True, timeout=5
        )
        names = [l.strip() for l in r.stdout.splitlines() if l.strip()]
        if names:
            return names[0]
    return None


def _detect_droid_mode(serial: str) -> str:
    r = subprocess.run(
        ["adb", "-s", serial, "shell", "su -c id 2>/dev/null || echo no-root"],
        capture_output=True, text=True, timeout=5
    )
    if "uid=0" in r.stdout:
        return "chroot"
    return "proot"


def _get_all_adb_serials() -> List[str]:
    try:
        r = subprocess.run(["adb", "devices"], capture_output=True, text=True, timeout=5)
        serials = []
        for line in r.stdout.strip().splitlines()[1:]:
            if not line.strip():
                continue
            parts = line.split()
            if len(parts) >= 2 and parts[1] == "device":
                serials.append(parts[0])
        return serials
    except Exception:
        return []


def _pick_adb_device(cfg: dict) -> Optional[str]:
    preferred = cfg.get("preferred_device") or ""
    serials = _get_all_adb_serials()
    if not serials:
        return None
    if preferred and preferred in serials:
        return preferred
    if len(serials) == 1:
        return serials[0]
    chosen = _fzf_pick(serials, "Select ADB device")
    return chosen or serials[0]


def resolve_connection(cfg: dict, preferred_serial: str = "") -> PhoneConn:
    global _conn_cache, _conn_cache_ts
    now = time.monotonic()
    if _conn_cache and now - _conn_cache_ts < CONN_CACHE_TTL:
        return _conn_cache

    conn = PhoneConn()

    # ADB serial — multi-device aware
    if cfg.get("adb_connect_string"):
        subprocess.run(["adb", "connect", cfg["adb_connect_string"]],
                       capture_output=True, timeout=5)
    serial = preferred_serial or cfg.get("preferred_device") or ""
    if serial:
        conn.adb_serial = serial
        conn.adb_ok = True
    else:
        all_serials = _get_all_adb_serials()
        if len(all_serials) == 1:
            conn.adb_serial = all_serials[0]
            conn.adb_ok = True
        elif len(all_serials) > 1:
            chosen = _fzf_pick(all_serials, "Select ADB device")
            if chosen:
                conn.adb_serial = chosen
                conn.adb_ok = True

    # Auto-connect ADB via IP if no serial
    if not conn.adb_serial and cfg.get("adb_connect_auto", True):
        iface = cfg.get("ssh_interface", "")
        for iface_candidate in [iface] if iface else _iter_wired_ifaces():
            try:
                r = subprocess.run(
                    ["ip", "-4", "neighbor", "show", "dev", iface_candidate],
                    capture_output=True, text=True, timeout=5
                )
                for line in r.stdout.splitlines():
                    parts = line.split()
                    if parts and parts[0] and "FAILED" not in line and "REACHABLE" in line:
                        ip = parts[0]
                        subprocess.run(["adb", "connect", f"{ip}:5555"],
                                       capture_output=True, timeout=5)
                        conn.iface = iface_candidate
                        break
                conn.iface = iface_candidate
                r2 = subprocess.run(["adb", "devices"], capture_output=True, text=True, timeout=3)
                for line2 in r2.stdout.strip().splitlines()[1:]:
                    if line2.strip() and "device" in line2:
                        conn.adb_serial = line2.split()[0]
                        conn.adb_ok = True
                        break
            except Exception:
                pass
            if conn.adb_ok:
                break

    # IP detection
    iface = cfg.get("ssh_interface", "")
    for iface_candidate in [iface] if iface else _iter_wired_ifaces():
        try:
            r = subprocess.run(
                ["ip", "-4", "neighbor", "show", "dev", iface_candidate],
                capture_output=True, text=True, timeout=5
            )
            for line in r.stdout.splitlines():
                parts = line.split()
                if parts and parts[0] and "FAILED" not in line and "REACHABLE" in line:
                    conn.ip = parts[0]
                    conn.iface = iface_candidate
                    break
        except Exception:
            pass
        if conn.ip:
            break
    if not conn.ip and iface:
        try:
            r = subprocess.run(
                ["ip", "-4", "route", "show", "dev", iface],
                capture_output=True, text=True, timeout=5
            )
            for line in r.stdout.splitlines():
                parts = line.split()
                if len(parts) > 2 and parts[0] == "default":
                    conn.ip = parts[2]
                    conn.iface = iface
        except Exception:
            pass

    # SSH port
    cfg_port = cfg.get("ssh_port") or 0
    if cfg_port:
        conn.ssh_port = cfg_port
    elif conn.ip:
        conn.ssh_port = _probe_ssh_port(conn.ip)

    # SSH user
    cfg_user = cfg.get("ssh_user") or ""
    if cfg_user:
        conn.ssh_user = cfg_user
    elif conn.adb_ok:
        try:
            r = subprocess.run(
                ["adb", "-s", conn.adb_serial.replace(" (unauthorized)", ""),
                 "shell", "id", "-un"],
                capture_output=True, text=True, timeout=5
            )
            conn.ssh_user = r.stdout.strip()
        except Exception:
            pass

    # SSH key
    cfg_key = cfg.get("ssh_key") or ""
    if cfg_key:
        conn.ssh_key = cfg_key
    else:
        conn.ssh_key = detect_ssh_key()

    # SSH connectivity probe
    if conn.ip and conn.ssh_user:
        try:
            r = subprocess.run(
                ["ssh", "-q", "-o", "ConnectTimeout=2",
                 "-o", "StrictHostKeyChecking=no",
                 "-p", str(conn.ssh_port),
                 "-o", "BatchMode=yes",
                 f"{conn.ssh_user}@{conn.ip}", "true"],
                capture_output=True, timeout=5
            )
            conn.ssh_ok = (r.returncode == 0)
        except Exception:
            conn.ssh_ok = False

    _conn_cache = conn
    _conn_cache_ts = now
    return conn


def get_adb_serial(cfg: dict) -> Optional[str]:
    conn = resolve_connection(cfg)
    return conn.adb_serial if conn.adb_ok else None


def require_adb(cfg: dict) -> str:
    conn = resolve_connection(cfg)
    if not conn.adb_ok:
        fatal("No ADB device connected.\nConnect via USB or enable wireless ADB.")
    return conn.adb_serial


def _get_host_info() -> dict:
    info = {}
    try:
        r = subprocess.run(["hostname"], capture_output=True, text=True, timeout=3)
        info["hostname"] = r.stdout.strip()
    except:
        info["hostname"] = "?"
    try:
        r = subprocess.run(["uname", "-r"], capture_output=True, text=True, timeout=3)
        info["kernel"] = r.stdout.strip()
    except:
        info["kernel"] = "?"
    try:
        r = subprocess.run(["uname", "-m"], capture_output=True, text=True, timeout=3)
        info["arch"] = r.stdout.strip()
    except:
        info["arch"] = "?"
    try:
        with open("/etc/os-release") as f:
            for line in f:
                if line.startswith("PRETTY_NAME="):
                    info["os"] = line.split("=", 1)[1].strip().strip('"')
                    break
        if "os" not in info:
            info["os"] = "Linux"
    except:
        info["os"] = "Linux"
    try:
        r = subprocess.run(["uptime", "-p"], capture_output=True, text=True, timeout=3)
        info["uptime"] = r.stdout.strip().replace("up ", "")
    except:
        info["uptime"] = "?"
    try:
        r = subprocess.run(["nproc"], capture_output=True, text=True, timeout=3)
        info["cpu"] = f"{r.stdout.strip()} cores"
    except:
        info["cpu"] = "?"
    desk = os.environ.get("XDG_SESSION_DESKTOP") or os.environ.get("DESKTOP_SESSION") or ""
    info["desktop"] = desk
    try:
        r = subprocess.run(["free", "-h"], capture_output=True, text=True, timeout=3)
        for line in r.stdout.splitlines():
            if line.startswith("Mem:"):
                parts = line.split()
                info["mem"] = f"{parts[2]} / {parts[1]}"
                break
    except:
        info["mem"] = "?"
    return info


def require_ssh_ip(cfg: dict) -> str:
    conn = resolve_connection(cfg)
    if not conn.ip:
        fatal("Could not detect phone IP.\nIs USB tethering or ethernet connected?")
    return conn.ip


def check_dep(cmd: str, hint: str = ""):
    if not shutil.which(cmd):
        msg = f"Required tool not found: {cmd}"
        if hint:
            msg += f"\nInstall: {hint}"
        fatal(msg)


# ── Interactive picker ─────────────────────────────────────────────────────────

def _fzf_pick(items: List[str], prompt: str = "Select") -> Optional[str]:
    if not items:
        return None
    if shutil.which("fzf"):
        input_data = "\n".join(items)
        r = subprocess.run(
            ["fzf", "--prompt", f"{prompt}: ", "--height=40%", "--border"],
            input=input_data, capture_output=True, text=True
        )
        return r.stdout.strip() or None
    print(f"\n{prompt}:")
    for i, item in enumerate(items, 1):
        print(f"  [{i}]  {item}")
    choice = _pick_number(len(items))
    return items[choice - 1] if choice else None


