        # ── Right panel: 2-column menu ──


        # ── Non-TTY fallback: just show left panel ──
        if not sys.stdin.isatty():
            _console.print(left_panel)
            return
        import termios, tty

        def _getch() -> str:
            fd = sys.stdin.fileno()
            old = termios.tcgetattr(fd)
            try:
                tty.setraw(fd)
                ch = os.read(fd, 1).decode()
                if ch == '\x1b':
                    import select
                    if select.select([sys.stdin], [], [], 0.05)[0]:
                        ch += os.read(fd, 2).decode()
                return ch
            finally:
                termios.tcsetattr(fd, termios.TCSADRAIN, old)

        def _run(args_list, term=False):
            if term:
                subprocess.Popen(["kitty", "-e", sys.argv[0]] + args_list, stdout=NULL, stderr=NULL)
            else:
                try:
                    r = subprocess.run([sys.argv[0]] + args_list, capture_output=True, text=True, timeout=30)
                    out = (r.stdout + r.stderr).strip()
                except subprocess.TimeoutExpired:
                    out = "Command timed out"
                if out:
                    _console.print(Panel(out, border_style="dim"))
                    _getch()

        def _nav(items, title="Menu", back=True):
            """Navigable menu using arrow/jk keys. Enter to select, Esc/q to go back."""
            cursor = 0
            while True:
                _console.clear()
                split = Table.grid(expand=True)
                split.add_column(ratio=3)
                split.add_column(ratio=7)
                right = Table.grid(padding=(0, 1))
                right.add_column()
                right.add_row(f"\n[bold cyan]{title}[/]")
                right.add_row("─" * 34)
                for i, item in enumerate(items):
                    marker = "[reverse]▸[/]" if i == cursor else " "
                    label = item.get("label", "")
                    right.add_row(f"  {marker}  {label}")
                if back:
                    bmarker = "[reverse]▸[/]" if cursor == len(items) else " "
                    right.add_row("")
                    right.add_row(f"  {bmarker}  ◂  Back")
                right.add_row("")
                right.add_row("[dim]↑↓/jk navigate  Enter select  Esc/q back[/]")
                split.add_row(left_panel, Panel(right, title="Menu", border_style="green"))
                _console.print(split)

                key = _getch()
                if key == 'q' or key == '\x1b':
                    return
                if key == '\x03':
                    sys.exit(0)
                if key in ('j', '\x1b[B'):  # down
                    cursor = min(cursor + 1, len(items))
                elif key in ('k', '\x1b[A'):  # up
                    cursor = max(cursor - 1, 0)
                elif key in ('\r', '\n'):
                    if cursor == len(items) and back:
                        return
                    item = items[cursor]
                    if "items" in item:
                        _nav(item["items"], item["label"])
                        cursor = 0
                    elif "action" in item:
                        item["action"]()
                        cursor = 0
                elif key == 'g':
                    cursor = 0
