    def adb_getprop(prop):
        r = subprocess.run(["adb", "-s", serial, "shell", f"getprop {prop}"],
                           capture_output=True, text=True, timeout=5)
        return r.stdout.strip()

    def adb_cmd(cmd):
        r = subprocess.run(["adb", "-s", serial, "shell", cmd],
                           capture_output=True, text=True, timeout=5)
        return r.stdout.strip()

    props = {}
    def fetch_prop(key, prop):
        props[key] = adb_getprop(prop)

    def fetch_cmd(key, cmd):
        props[key] = adb_cmd(cmd)

    with TPE(max_workers=6) as pool:
        pool.submit(fetch_prop, "model", "ro.product.model")
        pool.submit(fetch_prop, "brand", "ro.product.brand")
        pool.submit(fetch_prop, "codename", "ro.product.device")
        pool.submit(fetch_prop, "android", "ro.build.version.release")
        pool.submit(fetch_prop, "patch", "ro.build.version.security_patch")
        pool.submit(fetch_prop, "los", "ro.lineage.version")
        pool.submit(fetch_prop, "abis", "ro.product.cpu.abilist")
        pool.submit(fetch_cmd, "kernel", "uname -r")
        pool.submit(fetch_cmd, "mem", "cat /proc/meminfo | grep MemTotal")
        pool.submit(fetch_cmd, "storage", "df -h /data | tail -1")
        pool.submit(fetch_cmd, "display", "wm size")

    mem_raw = props.get("mem", "")
    if mem_raw:
