        dev.add_row(f"  [yellow]Android[/]    {android}")
        dev.add_row(f"  [yellow]IP[/]         {ip}")
        dev.add_row(f"  [yellow]Storage[/]    {storage}")
        dev.add_row(f"  [yellow]Serial[/]     {serial}")

        # Link info
        link = Table.grid(padding=(0, 1))
        link.add_column()
        link.add_row(f"[bold cyan]Data Link[/]")
        link.add_row(f"  [yellow]ADB[/]       {'✅ Connected' if conn.adb_serial else '❌ Not connected'}")
        link.add_row(f"  [yellow]SSH[/]       {'✅ Port ' + str(conn.ssh_port) if conn.ssh_port else '❌ Not configured'}")
        link.add_row(f"  [yellow]Tunnel[/]    {'🔒 Active' if ':1080' in r_ss.stdout else '🔓 Inactive'}")
